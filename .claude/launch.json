{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo-web",
      "runtimeExecutable": "/usr/local/bin/node",
      "runtimeArgs": ["/usr/local/bin/npx", "expo", "start", "--web", "--port", "8082"],
      "port": 8082,
      "autoPort": true,
      "env": {"PATH": "/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin"}
    },
    {
      "name": "expo-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--port", "8082"],
      "port": 8082
    },
    {
      "name": "expo-ios",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios", "--port", "8082"],
      "port": 8082
    },
    {
      "name": "expo-android",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--android", "--port", "8082"],
      "port": 8082
    },
    {
      "name": "supabase-functions",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "functions", "serve"],
      "port": 54321
    },
    {
      "name": "supabase-local",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["supabase", "start"],
      "port": 54323
    }
  ]
}
